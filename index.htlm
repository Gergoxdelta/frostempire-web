<!DOCTYPE html>
<html lang="hu">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>FrostEmpire</title>
  <link rel="stylesheet" href="style.css"/>
</head>
<body>

  <div class="snow"></div>

  <header>
    <h1>❄️ FrostEmpire</h1>
    <nav>
      <a href="index.html">Főoldal</a>
      <a href="shop.html">Webshop</a>
      <a href="rules.html">Szabályok</a>
    </nav>
  </header>

  <section class="hero">
    <h2>A jég birodalma vár rád</h2>
    <p>Csatlakozz most: <span id="ip">play.frostempire.hu</span></p>

    <button onclick="copyIP()">📋 IP másolása</button>
    <a class="discord" href="https://discord.gg/" target="_blank">💬 Discord</a>
  </section>

  <section class="status">
    <div class="card">🟢 Szerver: <b>Online</b></div>
    <div class="card">👥 Játékosok: <b>42 / 200</b></div>
    <div class="card">⚔️ Rangok: <b>5 elérhető</b></div>
  </section>

  <section class="top">
    <h2>🏆 Top játékosok</h2>
    <ul>
      <li>1. IceKing</li>
      <li>2. FrostyYT</li>
      <li>3. SnowBlade</li>
    </ul>
  </section>

  <footer>
    <p>© 2026 FrostEmpire</p>
  </footer>

  <script src="script.js"></script>
</body>
</html>